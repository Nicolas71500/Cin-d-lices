      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 602.9961210546776,
      "y": 425.7046291379482,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 202.99317932128906,
      "height": 104.00000000000014,
      "seed": 1946748989,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
